OPENAI_API_KEY=your_key_here

# API key to protect your /analyze endpoint (judges will use this)
API_KEY=docanalyzer-2026-secret


# Optional: path to Tesseract binary (required on Windows)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# AI backend: "huggingface" (default) or "openai"
AI_BACKEND=huggingface
